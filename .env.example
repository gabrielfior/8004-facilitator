# Facilitator Service Configuration
# ERC-8004 on Ethereum Sepolia + x402 on Base / Ethereum Sepolia

# ============================================
# Required Environment Variables
# ============================================

# RPC URL for x402 payment network (Base Sepolia, or Ethereum Sepolia if using eth-sepolia)
RPC_URL=https://sepolia.base.org

# RPC URL for ERC-8004 registry network (Ethereum Sepolia)
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ERC-8004 Identity Registry contract address (Ethereum Sepolia)
# The contract that manages agent registration
ERC8004_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ERC-8004 Reputation Registry contract address (Ethereum Sepolia)
# The contract that manages agent feedback and reputation
ERC8004_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Delegate contract address for EIP-7702 (Ethereum Sepolia)
# The contract that handles delegated operations (agent registration, feedback)
DELEGATE_CONTRACT_ADDRESS=0x252367B463f77EFe33c151E9d9821788090EC4b5

# Facilitator's private key (without 0x prefix is fine, it will be normalized)
# This key is used to sign transactions on behalf of clients
# WARNING: Keep this secure and never commit it to version control
FACILITATOR_PRIVATE_KEY=

# ============================================
# Optional Environment Variables
# ============================================

# Port for the facilitator service (default: 4022)
PORT=4022

# Redis URL for caching agent address -> ID mappings (optional)
# If not provided, uses in-memory storage
REDIS_URL=

# Per-chain ERC-8004 RPC URLs (override defaults)
# ERC8004_RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# ERC8004_RPC_URL_11155111=https://ethereum-sepolia-rpc.publicnode.com

# Per-chain Delegate contract addresses (override defaults)
# DELEGATE_CONTRACT_ADDRESS_1=0x<deployed_address>
# DELEGATE_CONTRACT_ADDRESS_11155111=0x252367B463f77EFe33c151E9d9821788090EC4b5
